# Public — exposed to the browser. Anything starting NEXT_PUBLIC_ is bundled.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe publishable key (test mode). Used by Stripe Elements only — never the secret.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replaceme

# Server-only (loaded by Next runtime; never exposed).
NODE_ENV=development
